<% layout('layouts/boilerplate') %>

    <h1>ALL CAMPGROUNDS</h1>
    <a href="/campgrounds/new">New Campground</a>
    
    <div class="card">
        <% for(let campground of campgrounds){ %>
            <div class="row mb-2">
                <div class="col-md-4">
                    <img class="img-fluid" src="<%= campground.image %>" alt="">
                </div>

                <div class="col-md-8">
                    <div class="card-body">
                        <h5 class="card-title">
                            <%= campground.title %>
                        </h5>
                        <p class="card-text">
                            <%= campground.description %>
                        </p>
                        <p class="card-text">
                            <small class="text">
                                <%= campground.location%>
                            </small>
                        </p>
                        <a class="btn btn-primary"  href="/campgrounds/<%= campground._id %>">View <%= campground.title %></a>
                    </div>
                </div>
            </div>


        <% } %>

    </div>
    
    
